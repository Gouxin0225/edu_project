<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.edubackend.mapper.StudentAnswerDetailMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.edubackend.entity.StudentAnswerDetail">
        <id column="id" property="id" />
        <result column="submission_id" property="submissionId" />
        <result column="question_id" property="questionId" />
        <result column="student_answer" property="studentAnswer" />
        <result column="is_correct" property="isCorrect" />
        <result column="score_gained" property="scoreGained" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, submission_id, question_id, student_answer, is_correct, score_gained
    </sql>

</mapper>
