<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.edubackend.mapper.SysClassMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.edubackend.entity.SysClass">
        <id column="id" property="id" />
        <result column="class_name" property="className" />
        <result column="status" property="status" />
        <result column="school_name" property="schoolName" />
        <result column="allow_student_apply" property="allowStudentApply" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="is_deleted" property="isDeleted" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, class_name, status, school_name, allow_student_apply, create_time, update_time, is_deleted
    </sql>

</mapper>
