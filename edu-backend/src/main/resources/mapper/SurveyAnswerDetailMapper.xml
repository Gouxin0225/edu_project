<mapper namespace="com.example.edubackend.mapper.SurveyAnswerDetailMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.edubackend.entity.SurveyAnswerDetail">
        <id column="id" property="id" />
